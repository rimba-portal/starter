{
    "name": "bit-es/siapa",
    "description": "Filament Identity: Wizard Login + Face Verification + TOTP, separate auth table",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "laravel/framework": "^13.0",
        "filament/filament": "^5.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bites\\Identity\\IdentityServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Bites\\Identity\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}