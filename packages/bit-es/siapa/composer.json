{
    "name": "bit-es/versioning",
    "description": "Versioning package for use by any model records in Laravel Filament.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bites\\Versioning\\VersioningServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Bites\\Versioning\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}