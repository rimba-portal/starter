{
    "name": "bites/identity",
    "description": "Filament Identity: Wizard Login + Face Verification + TOTP, separate auth table",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bites\\Identity\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Bites Team",
            "email": "dev@bites.my"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "laravel/framework": "^11.0|^12.0",
        "filament/filament": "^5.0",
        "filament/multi-factor-authentication": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bites\\Identity\\IdentityServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}