{
    "name": "bit-es/agreement",
    "description": "Agreement package for use bind/link model records together as parties and artifacts, on the scope and duration of the pact.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bites\\Agreement\\AgreementServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Bites\\Agreement\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}