{
    "name": "rimba/twig",
    "description": "Attributing package for use by any model records to create ABAC in Laravel Filament.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rimba\\Twig\\Dms\\DmsServiceProvider",
                "Rimba\\Twig\\Eam\\EamServiceProvider",
                "Rimba\\Twig\\Hrm\\HrmServiceProvider",
                "Rimba\\Twig\\Lcs\\LcsServiceProvider",
                "Rimba\\Twig\\Lms\\LmsServiceProvider",
                "Rimba\\Twig\\Tos\\TosServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Rimba\\Twig\\Dms\\": "Dms/src",
            "Rimba\\Twig\\Eam\\": "Eam/src",
            "Rimba\\Twig\\Hrm\\": "Hrm/src",
            "Rimba\\Twig\\Lcs\\": "Lcs/src",
            "Rimba\\Twig\\Lms\\": "Lms/src",
            "Rimba\\Twig\\Tos\\": "Tos/src"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}