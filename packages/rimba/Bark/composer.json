{
    "name": "rimba/bark",
    "description": "Enhancement and modification add on to the application (Tree)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rimba\\Bark\\Who\\WhoServiceProvider",
                "Rimba\\Bark\\Can\\CanServiceProvider",
                "Rimba\\Bark\\Branding\\BrandingServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Rimba\\Bark\\Who\\": "Who/src",
            "Rimba\\Bark\\Can\\": "Can/src",
            "Rimba\\Bark\\Branding\\": "Branding/src"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}