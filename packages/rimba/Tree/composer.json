{
    "name": "rimba/tree",
    "description": "Attributing package for use by any model records to create ABAC in Laravel Filament.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rimba\\Tree\\Work\\WorkServiceProvider",
                "Rimba\\Tree\\Flow\\FlowServiceProvider",
                "Rimba\\Tree\\Time\\TimeServiceProvider",
                "Rimba\\Tree\\Link\\LinkServiceProvider",
                "Rimba\\Tree\\Menu\\MenuServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Rimba\\Tree\\Work\\": "Work/src",
            "Rimba\\Tree\\Flow\\": "Flow/src",
            "Rimba\\Tree\\Time\\": "Time/src",
            "Rimba\\Tree\\Link\\": "Link/src",
            "Rimba\\Tree\\Menu\\": "Menu/src"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}