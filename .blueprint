models:
    Models\User: { name: string, email: string, email_verified_at: 'datetime nullable', password: string, remember_token: 'string nullable' }
    Trees\Sync\Models\ApiConfig: { name: 'string unique index', source_type: string, source_config: json, data_path: 'string nullable', depends_on: 'json nullable', mapping: json, active: 'boolean default:true index', relationships: { hasMany: ApiData } }
    Trees\Sync\Models\ApiData: { api_config_id: 'id foreign:api_configs cascadeOnDelete', fingerprint: 'string nullable index', payload: json, status: 'string default:pending index', processed_at: 'timestamp nullable', error: 'text nullable' }
    Trees\AuditTrail\Models\AuditLog: { user_id: 'id nullable foreign:users', staff_id: 'id nullable foreign:staff', result: 'string nullable', actor: string, action: string, reason: 'string nullable', metadata: 'json nullable', relationships: { morphTo: ref } }
    Trees\Copies\Models\Versionable: { type: 'enum:document,workflow,template,service,config,other', name: string, current_version_id: 'id nullable foreign:versions', attributes: 'json nullable', relationships: { morphTo: ref, hasMany: Version } }
    Trees\Copies\Models\Version: { versionable_id: 'id foreign:versionables', created_by: 'id nullable foreign:staff', approved_by: 'id nullable foreign:staff', published_by: 'id nullable foreign:staff', status: 'enum:draft,approved,published,archived,rejected', content_type: 'enum:file,url,inline,json nullable', content_path: 'string nullable', major: integer, minor: integer, patch: integer, version: string, change_summary: 'string nullable', change_notes: 'text nullable', is_menu: boolean, approved_at: 'timestamp nullable', published_at: 'timestamp nullable', effective_from: 'timestamp nullable', effective_to: 'timestamp nullable', attributes: 'json nullable', relationships: { hasMany: 'VersionApproval, VersionRelation:relations, VersionRelation:relatedRelations' } }
    Trees\Copies\Models\VersionApproval: { version_id: 'id foreign:versions', user_id: 'id foreign:staff' }
    Trees\Copies\Models\VersionRelation: { version_id: 'id foreign:versions', related_version_id: 'id foreign:versions' }
    Trees\Copies\Models\VersionLock: { version_id: 'id foreign:versions', locked_by: 'id foreign:staff' }
    Trees\FloorPlan\Models\Location: { parent_id: 'id nullable foreign:locations', org_corp_id: 'id nullable foreign:org_corps', type: 'enum:site,building,area,section,room,zone,other nullable', name: string, attributes: 'json nullable', relationships: { hasMany: 'Location:children, LocationAssignment' } }
    Trees\FloorPlan\Models\LocationAssignment: { location_id: 'id foreign:locations', type: 'enum:primary,secondary,temporary nullable', start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable', relationships: { morphTo: assignable } }
    Trees\Agreement\Models\ContractType: { uuid: 'uuid unique', name: string, code: 'string unique', description: 'text nullable', template: 'longtext nullable', public_schema: 'json nullable', confidential_schema: 'json nullable', notify: 'json nullable', expiry_notify_days: 'integer default:30', requires_approval: 'boolean default:false', requires_signature: 'boolean default:false', workflow_id: 'id nullable foreign:workflows', meta: 'json nullable', relationships: { hasMany: Contract } }
    Trees\Agreement\Models\Contract: { uuid: 'uuid unique', contract_type_id: 'id foreign:contract_types', org_corp_id: 'id nullable foreign:org_corps', contract_no: 'string nullable', title: string, summary: 'text nullable', start_date: 'date nullable', end_date: 'date nullable', renewal_date: 'date nullable', status: 'enum:draft,pending,active,expired,terminated,archived default:draft', terms: 'json nullable', meta: 'json nullable', relationships: { morphTo: contractable, hasOne: ContractConfidentiality, hasMany: ContractParty } }
    Trees\Agreement\Models\ContractParty: { contract_id: 'id foreign:contracts', role: 'string nullable', is_signatory: 'boolean default:false', notify_on_expiry: 'boolean default:true', meta: 'json nullable', relationships: { morphTo: Party } }
    Business\Lcs\Models\ContractConfidentiality: { contract_id: 'id foreign:contracts unique', payload: hashed, allowed_roles: 'json nullable', meta: 'json nullable' }
    Trees\Todo\Models\Task: { role_id: 'id nullable foreign:roles', staff_id: 'id nullable foreign:staff', task_list_id: 'id nullable foreign:task_lists', title: string, description: 'text nullable', relationships: { morphTo: ref, hasMany: TaskAssignment, belongsTo: \Spatie\Permission\Models\Role } }
    Trees\Todo\Models\TaskList: { name: string, relationships: { hasMany: Task, morphTo: ref } }
    Trees\Todo\Models\TaskTemplate: { role_id: 'id nullable foreign:roles', name: string, relationships: { hasMany: TaskListTemplateItem, belongsTo: \Spatie\Permission\Models\Role } }
    Trees\Todo\Models\TaskListTemplate: { name: string, relationships: { hasMany: TaskListTemplateItem } }
    Trees\Todo\Models\TaskListTemplateItem: { task_list_template_id: 'id foreign:task_list_templates', task_template_id: 'id foreign:task_templates', depends_on_id: 'id nullable foreign:task_list_template_items', relationships: { hasMany: 'TaskListTemplateItem:dependents' } }
    Trees\Todo\Models\TaskAssignment: { task_id: 'id foreign:tasks', role_id: 'id nullable foreign:roles', staff_id: 'id nullable foreign:staff', assigned_by: 'id nullable foreign:staff', relationships: { belongsTo: \Spatie\Permission\Models\Role } }
    Trees\Calendar\Models\Event: { org_corp_id: 'id nullable foreign:org_corps', org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', type: 'enum:holiday,company,operational,training,maintenance,other', name: string, description: 'text nullable', start_at: timestamp, end_at: 'timestamp nullable', is_blocking: 'boolean default:false', attributes: 'json nullable' }
    Trees\Organization\Models\OrgCorp: { name: string, code: 'string nullable', uuid: 'string unique', type: 'enum:company,government,vendor,institution nullable', attributes: 'json nullable', relationships: { hasMany: OrgUnit } }
    Trees\Organization\Models\OrgUnit: { org_corp_id: 'id nullable foreign:org_corps', parent_id: 'id nullable foreign:org_units', name: string, code: 'string nullable', uuid: 'string unique', description: 'string nullable', attributes: 'json nullable', relationships: { hasMany: 'OrgUnit:children, OrgTeam' } }
    Trees\Organization\Models\OrgTeam: { org_unit_id: 'id foreign:org_units', name: string, code: 'string nullable', is_active: 'boolean default:true', attributes: 'json nullable', relationships: { hasMany: 'Workflow, JobContract' } }
    Trees\Organization\Models\JobContract: { uuid: 'string unique', job_position_id: 'id nullable foreign:job_positions', staff_id: 'id nullable foreign:staff', issuing_org_corp_id: 'id foreign:org_corps', contract_type: 'enum:FTE,FTC,TPC,INTERN nullable', start_date: 'date nullable', end_date: 'date nullable', relationships: { hasOne: OrgCorp, hasMany: JobPosition } }
    Trees\Organization\Models\JobPosition: { job_contract_id: 'id foreign:job_contracts', org_unit_id: 'id nullable foreign:org_units', level: 'enum:junior,mid,senior,lead,manager nullable', status: 'enum:open,filled,closed default:open', title: string, description: 'text nullable', attributes: 'json nullable', relationships: { hasMany: StaffPosition } }
    Trees\Organization\Models\JobRole: { type: 'enum:approval,operation,admin,reporting nullable', name: string, description: 'text nullable', attributes: 'json nullable' }
    Trees\Organization\Models\JobPositionRole: { job_position_id: 'id foreign:job_positions', job_role_id: 'id foreign:job_roles' }
    Trees\Organization\Models\Staff: { user_id: 'id nullable foreign:users', org_corp_id: 'id nullable foreign:org_corps', org_unit_id: 'id nullable foreign:org_units', job_contract_id: 'id nullable foreign:job_contracts', type: 'enum:FTE,FTC,TPC,Intern default:FTE', status: 'enum:active,inactive,suspended default:active', name: 'string nullable', staff_no: 'string nullable', attributes: 'json nullable', relationships: { hasMany: 'StaffPosition, Request', morphMany: 'AuditLog:model' } }
    Trees\Organization\Models\StaffPosition: { staff_id: 'id foreign:staff', job_position_id: 'id foreign:job_positions', assignment_type: 'enum:primary,secondary,acting default:primary', status: 'enum:active,ended,pending default:active', start_date: date, end_date: 'date nullable', attributes: 'json nullable' }
    Trees\Organization\Models\Movement: { type: 'enum:transfer,promotion,demotion,assignment,end_of_assignment', effective_date: date, from: 'json nullable', to: 'json nullable', relationships: { morphTo: movable } }
    Trees\Authorization\Models\StaffRole: { staff_id: 'id foreign:staff', role_id: 'id foreign:roles', org_corp_id: 'id nullable foreign:org_corps', org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', job_position_id: 'id nullable foreign:job_positions', job_role_id: 'id nullable foreign:job_roles', job_contract_id: 'id nullable foreign:job_contracts', source: 'enum:auto,manual default:auto', status: 'enum:active,inactive default:active', start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable', relationships: { belongsTo: \Spatie\Permission\Models\Role } }
    Trees\Authorization\Models\RoleAssignment: { role_id: 'id foreign:roles', staff_id: 'id foreign:staff', assigned_by: 'id nullable foreign:staff', org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable', relationships: { belongsTo: \Spatie\Permission\Models\Role } }
    Trees\Calendar\Models\Shift: { org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', staff_id: 'id nullable foreign:staff', type: 'enum:fixed,rotational nullable', name: string, description: 'text nullable', start_time: time, end_time: time, start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable' }
    Trees\Process\Models\Workflow: { org_team_id: 'id foreign:org_teams', start_step_id: 'id nullable foreign:workflow_steps', name: string, description: 'text nullable', is_active: 'boolean default:true', attributes: 'json nullable', relationships: { hasMany: 'WorkflowStep, WorkflowInstance' } }
    Trees\Process\Models\WorkflowStep: { workflow_id: 'id foreign:workflows', type: 'enum:start,process,decision,end default:process', name: string, description: 'text nullable', requires_tasks: 'boolean default:false', requires_decision: 'boolean default:false', is_automatic: 'boolean default:false', attributes: 'json nullable', relationships: { hasMany: 'WorkflowTransition:from_transitions, WorkflowTransition:to_transitions, WorkflowStepTask, WorkflowInstanceStep, WorkflowDecision' } }
    Trees\Process\Models\WorkflowTransition: { workflow_id: 'id foreign:workflows', from_step_id: 'id foreign:workflow_steps', to_step_id: 'id foreign:workflow_steps', name: 'string nullable', conditions: 'json nullable', requires_approval: 'boolean default:false', attributes: 'json nullable' }
    Trees\Process\Models\WorkflowStepTask: { workflow_step_id: 'id foreign:workflow_steps', task_template_id: 'id nullable foreign:task_templates', task_list_template_id: 'id nullable foreign:task_list_templates', is_required: 'boolean default:true', attributes: 'json nullable' }
    Trees\Process\Models\WorkflowInstance: { workflow_id: 'id foreign:workflows', current_step_id: 'id nullable foreign:workflow_steps', status: 'enum:active,completed,cancelled default:active', started_at: 'timestamp nullable', completed_at: 'timestamp nullable', attributes: 'json nullable', relationships: { morphTo: ref, hasMany: 'WorkflowInstanceStep, WorkflowDecision' } }
    Trees\Process\Models\WorkflowInstanceStep: { workflow_instance_id: 'id foreign:workflow_instances', workflow_step_id: 'id foreign:workflow_steps', status: 'enum:pending,active,completed,skipped default:pending', started_at: 'timestamp nullable', completed_at: 'timestamp nullable', attributes: 'json nullable' }
    Trees\Process\Models\WorkflowDecision: { workflow_instance_id: 'id foreign:workflow_instances', workflow_step_id: 'id foreign:workflow_steps', user_id: 'id foreign:staff', decision: 'enum:approve,reject,request_changes', comment: 'text nullable', decided_at: timestamp, attributes: 'json nullable' }
    Business\Hrm\Models\Employee: { staff_id: 'id foreign:staff', org_corp_id: 'id foreign:org_corps', status: 'enum:active,resigned,terminated,retired default:active', employee_no: 'string nullable', hire_date: 'date nullable', termination_date: 'date nullable', attributes: 'json nullable' }
    Business\Hrm\Models\JobTitle: { title: string, jobgrade: 'string nullable', uuid: 'uuid unique', description: 'text nullable', attributes: 'json nullable', masco_code: 'string nullable' }
    Business\Tos\Models\Request: { requester_id: 'id foreign:staff', workflow_instance_id: 'id nullable foreign:workflow_instances', status: 'enum:submitted,in_review,approved,rejected,in_progress,completed,closed default:submitted', name: 'string nullable', description: 'text nullable', request_type: 'string nullable', attributes: 'json nullable', relationships: { morphTo: ref } }
    Business\Tos\Models\RequestType: { workflow_id: 'id nullable foreign:workflows', name: string, attributes: 'json nullable' }
    Business\Tos\Models\Offer: { org_team_id: 'id foreign:org_teams', name: string, description: 'text nullable', attributes: 'json nullable', relationships: { morphOne: Versionable, hasMany: OfferCategoryAssignment } }
    Business\Tos\Models\OfferCategory: { parent_id: 'id nullable foreign:Offer_categories', name: string, description: 'text nullable', attributes: 'json nullable', relationships: { hasMany: 'OfferCategory:children, OfferCategoryAssignment' } }
    Business\Tos\Models\OfferCategoryAssignment: { offer_id: 'id foreign:offers', offer_category_id: 'id foreign:offer_categories', attributes: 'json nullable' }
    Business\Dms\Models\Document: { org_team_id: 'id foreign:org_teams', org_unit_id: 'id nullable foreign:org_units', location_id: 'id nullable foreign:locations', type: 'enum:sop,work_instruction,policy,drawing,contract,other nullable', title: string, description: 'text nullable', attributes: 'json nullable', relationships: { morphOne: Versionable, hasMany: DocumentCategoryAssignment } }
    Business\Dms\Models\DocumentCategory: { parent_id: 'id nullable foreign:document_categories', name: string, description: 'text nullable', attributes: 'json nullable', relationships: { hasMany: 'DocumentCategory:children, DocumentCategoryAssignment' } }
    Business\Dms\Models\DocumentCategoryAssignment: { document_id: 'id foreign:documents', document_category_id: 'id foreign:document_categories', attributes: 'json nullable' }
    Business\Lms\Models\Course: { org_team_id: 'id foreign:org_teams', code: 'string unique', title: string, description: 'text nullable', is_active: 'boolean default:true', attributes: 'json nullable', relationships: { hasMany: 'CourseModule, CourseGroupAssignment' } }
    Business\Lms\Models\CourseGroup: { parent_id: 'id nullable foreign:course_groups', name: string, description: 'text nullable', attributes: 'json nullable', relationships: { hasMany: 'CourseGroup:children, CourseGroupAssignment' } }
    Business\Lms\Models\CourseGroupAssignment: { course_id: 'id foreign:courses', course_group_id: 'id foreign:course_groups', attributes: 'json nullable' }
    Business\Lms\Models\Module: { name: string, description: 'text nullable', duration_minutes: 'integer nullable', validity_days: 'integer nullable', attributes: 'json nullable', relationships: { hasMany: 'CourseModule, MaterialModule, Quiz, Certificate' } }
    Business\Lms\Models\CourseModule: { course_id: 'id foreign:courses', module_id: 'id foreign:modules', sequence: 'integer nullable', attributes: 'json nullable' }
    Business\Lms\Models\Material: { org_team_id: 'id nullable foreign:org_teams', type: 'enum:document,video,link,other nullable', name: string, description: 'text nullable', attributes: 'json nullable', relationships: { hasMany: MaterialModule, morphOne: Versionable } }
